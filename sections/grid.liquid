{{ 'grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'grid.js' | asset_url }}" defer></script>
<section class="gift-guide-grid">
  <h2 class="grid-heading">{{ section.settings.grid_heading }}</h2>

  <div class="products-grid">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product %}
        <div class="grid-item" data-product="{{ product | json | escape }}" {{ block.shopify_attributes }}>
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.title | escape }}"
            class="grid-item__image"
            loading="lazy"
          />
          <button
            type="button"
            class="grid-item__plus-btn"
            aria-label="View {{ product.title | escape }} details"
            style="left: {{block.settings.marker_x}}%; top: {{block.settings.marker_y}}%;"
          >
            +
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="product-popup" id="productPopup" hidden>
    <div class="product-popup__overlay" data-popup-close></div>
    <div class="product-popup__content">
      <button type="button" class="product-popup__close" data-popup-close aria-label="Close">×</button>

      <img class="product-popup__image" src="#" alt="" />

      <div class="product-popup__details">
        <h3 class="product-popup__title"></h3>
        <p class="product-popup__price"></p>
        <p class="product-popup__description"></p>

        <div class="product-popup__options"></div>

        <button type="button" class="product-popup__add-btn">ADD TO CART →</button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gift Guide Grid",
  "settings": [
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Section heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        },
        {
          "type": "range",
          "id":"marker_x",
          "label": "Marker horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default":50
        },
        {
          "type": "range",
          "id": "marker_y",
          "label": "Marker horizontal position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default":50
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Gift Guide Grid",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
