<section class="gift-guide-banner" style="background-color: {{ section.settings.background_color }};">

  <div class="banner-top">

    <div class="banner-logo">
      {{ section.settings.logo_text }}
    </div>

    <div class="banner-message">
      {{ section.settings.banner_message }}
    </div>

    <a href="{{ section.settings.choose_gift_link }}"
       class="banner-btn banner-btn--yellow">
      {{ section.settings.choose_gift_text }}
    </a>

  </div>
  <div class="banner-main">

  <div class="banner-image">
    {% if section.settings.banner_image %}
      <img   
        class="banner-image__img"
        src="{{ section.settings.banner_image | image_url }}"
        alt="{{ section.settings.heading }}"
      />
    {% endif %}
  </div>

  <div class="banner-content">

    <h1 class="banner-heading">
      {{ section.settings.heading }}
    </h1>

    <p class="banner-description">
      {{ section.settings.description }}
    </p>

    <a
      href="{{ section.settings.shop_now_link }}"
      class="banner-btn banner-btn--black"
    >
      {{ section.settings.shop_now_text }}
    </a>

  </div>

</div>

<div class="banner-footer">
  {{ section.settings.footer_text }}
</div>

</section>

{% schema %}
{
  "name": "Gift Guide Banner",

  "settings": [

    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo",
      "default": "TISSO VISION"
    },

    {
      "type": "text",
      "id": "banner_message",
      "label": "Top Message",
      "default": "Find the ideal gift for your loved ones."
    },

    {
      "type": "text",
      "id": "choose_gift_text",
      "label": "Choose Gift Button Text",
      "default": "CHOOSE GIFT"
    },

    {
      "type": "url",
      "id": "choose_gift_link",
      "label": "Choose Gift Button Link"
    },
    {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default":"The Gift Guide"
    },
    {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Discover Joy: Your Ultimate Holiday Gift Destination..."
    },
    {
        "type": "text",
        "id": "shop_now_text",
        "label": "Shop Now Button",
        "default": "SHOP NOW"
    },
    {
        "type": "url",
        "id": "shop_now_link",
        "label": "Shop Now Link"
    },
    {
        "type": "text",
        "id": "footer_text",
        "label": "Footer Text",
        "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
        "type": "image_picker",
        "id": "banner_image",
        "label": "Banner Image"
    },
    {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#F5E6C8"
    }
  ],

  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}