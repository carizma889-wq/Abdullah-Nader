{{ 'banner.css' | asset_url | stylesheet_tag }}
<script src="{{ 'banner.js' | asset_url }}" defer></script>

<section class="gift-guide-banner" style="background-color: {{ section.settings.background_color }};">
  <div class="banner-top" >
    <div class="banner-logo">
      <img src="{{ 'logo.png' | asset_url }}"alt="Logo"/>
    </div>

    <div class="banner-message">
      <p> {{ section.settings.banner_message }}</p>
    </div>
    <a href="{{ section.settings.choose_gift_link }}" class="banner-btn banner-btn--yellow choose_gift_text" id="btnHeader"> {{ section.settings.choose_gift_text }}</a>

  </div>

<div class="banner-main">


  <div class="banner-content">

    <h1 class="banner-heading">
      {{ section.settings.heading }}
    </h1>

    <p class="banner-description">
      {{ section.settings.description }}
    </p>

    <a
      href="{{ section.settings.shop_now_link }}"
      class="banner-btn banner-btn--black"
    >
      {{ section.settings.shop_now_text }}
    </a>

  </div>

</div>

<div class="banner-footer">
  {{ section.settings.footer_text }}
</div>


</section>


{% schema %}
{
  "name": "Gift Guide Banner",

  "settings": [

    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo"
    },

    {
      "type": "text",
      "id": "banner_message",
      "label": "Top Message",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "banner_message_mobile",
      "label": "Top Message (Mobile)",
      "default": "Find the ideal gift for your loved ones."
    },

    {
      "type": "text",
      "id": "choose_gift_text",
      "label": "Choose Gift Button Text",
      "default": "CHOOSE GIFT"
    },

    {
      "type": "url",
      "id": "choose_gift_link",
      "label": "Choose Gift Button Link"
    },
    {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default":"The Gift Guide"
    },
    {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
    "type": "textarea",
    "id": "description_mobile",
    "label": "Description (Mobile)",
    "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
        "type": "text",
        "id": "shop_now_text",
        "label": "Shop Now Button",
        "default": "SHOP NOW"
    },
    {
        "type": "url",
        "id": "shop_now_link",
        "label": "Shop Now Link"
    },
    {
        "type": "text",
        "id": "footer_text",
        "label": "Footer Text",
        "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
        "type": "image_picker",
        "id": "banner_image",
        "label": "Banner Image"
    },
    {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#F5E6C8"
    }
  ],

  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %} 